%%{ init: { "theme": "default", "flowchart": { "curve": "basis" } } }%%
flowchart TD
    trigger["<b>When an HTTP request is received</b><br/><i>POST from Pi webhook caller</i><br/>section_name, page_title, html_body,<br/>notion_page_id, action, onenote_page_id,<br/>onenote_section_id, page_level"]

    init_vars["<b>Initialize variables</b><br/>var_section_id = onenote_section_id<br/>var_onenote_page_id = onenote_page_id"]

    cond_section{"Is var_section_id<br/>empty?"}

    get_sections["<b>Get sections in notebook</b><br/><i>OneNote Business connector</i><br/>Notebook: Class Notebook"]

    filter_sections["<b>Filter array</b><br/>displayName == section_name"]

    cond_exists{"Filter result<br/>length > 0?"}

    set_existing["<b>Set var_section_id</b><br/>= first(filter)?['id']"]

    subgraph one_copy ["<b>.one File Copy Workaround</b>"]
        direction TB
        create_personal["<b>Create section</b><br/><i>OneNote Business connector</i><br/>Personal OneDrive notebook<br/>Name: section_name"]

        copy_file["<b>Copy file</b><br/><i>SharePoint connector</i><br/>Source: OneDrive/.../section_name.one<br/>Dest: Class NB SharePoint path"]

        delay["<b>Delay</b><br/>45 seconds"]

        get_sections2["<b>Get sections in notebook</b><br/><i>OneNote Business connector</i><br/>Notebook: Class Notebook"]

        filter2["<b>Filter array</b><br/>displayName == section_name"]

        set_new["<b>Set var_section_id</b><br/>= first(filter)?['id']"]

        cleanup["<b>Delete file</b><br/><i>OneDrive connector</i><br/>Remove .one from personal NB"]

        create_personal --> copy_file --> delay --> get_sections2 --> filter2 --> set_new --> cleanup
    end

    cond_action{"action ==<br/>'create'?"}

    subgraph create_block ["<b>Create Page</b>"]
        create_page["<b>Create page in a section</b><br/><i>OneNote Business connector</i><br/>Section: var_section_id<br/>Content: html_body"]
        set_page_id["<b>Set var_onenote_page_id</b><br/>= new page ID"]
        create_page --> set_page_id
    end

    subgraph update_block ["<b>Update Page</b>"]
        update_page["<b>Update page content</b><br/><i>OneNote Business connector</i><br/>Page: var_onenote_page_id<br/>Content: append html_body"]
    end

    response["<b>Response</b> (HTTP 200)<br/>{<br/>  onenote_page_id: var_onenote_page_id,<br/>  onenote_section_id: var_section_id,<br/>  status: 'success'<br/>}"]

    trigger --> init_vars --> cond_section
    cond_section -- "YES (empty)" --> get_sections
    cond_section -- "NO (provided)" --> cond_action
    get_sections --> filter_sections --> cond_exists
    cond_exists -- "YES (found)" --> set_existing --> cond_action
    cond_exists -- "NO (not found)" --> one_copy --> cond_action
    cond_action -- "create" --> create_block --> response
    cond_action -- "update" --> update_block --> response

    classDef trigger fill:#4A90D9,stroke:#2C5F8A,color:#fff
    classDef action fill:#F5F5F5,stroke:#999,color:#333
    classDef condition fill:#FFF3CD,stroke:#D4A017,color:#333
    classDef subgraphStyle fill:#FFF0F0,stroke:#CC5555
    classDef response fill:#D4EDDA,stroke:#28A745,color:#333

    class trigger trigger
    class init_vars,get_sections,filter_sections,set_existing,create_page,set_page_id,update_page action
    class create_personal,copy_file,delay,get_sections2,filter2,set_new,cleanup action
    class cond_section,cond_exists,cond_action condition
    class response response
